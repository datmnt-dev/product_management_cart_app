rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserDoc() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return hasUserDoc() ? userDoc().data.role : null;
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isManager() {
      return role() == 'manager';
    }

    function isStaff() {
      return isAdmin() || isManager();
    }

    function isCustomer() {
      return role() == 'customer';
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isStaff());
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'customer';
      allow update: if signedIn()
        && (
          isAdmin()
          || (
            request.auth.uid == userId
            && request.resource.data.role == resource.data.role
          )
        );
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if signedIn();
      allow create, delete: if isStaff();
      // Customer may decrease (checkout) or increase (cancel restock) stock only.
      // Lab trust model — no Cloud Functions; client only uses these paths.
      allow update: if isStaff()
        || (
          isCustomer()
          && resource.data.status == 'active'
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['stockQuantity', 'updatedAt'])
          && request.resource.data.stockQuantity is int
          && request.resource.data.stockQuantity >= 0
        );
    }

    match /orders/{orderId} {
      function orderOwnedByCaller() {
        return request.auth.token.email is string
          && resource.data.userEmail is string
          && resource.data.userEmail.lower() == request.auth.token.email.lower();
      }

      function onlyStatusFieldsChanged() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updatedAt', 'statusHistory', 'stockRestored']);
      }

      function onlyPaymentFieldsChanged() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['paymentStatus', 'updatedAt']);
      }

      // Staff owns store fulfillment: receive, prepare, hand over to shipping.
      // Customer alone confirms actual receipt.
      function staffStatusUpdateOk() {
        return isStaff()
          && onlyStatusFieldsChanged()
          && (
            (
              resource.data.status in ['placed', 'pending']
              && request.resource.data.status in ['confirmed', 'cancelled']
            )
            || (
              resource.data.status == 'confirmed'
              && request.resource.data.status in ['preparing', 'cancelled']
            )
            || (
              resource.data.status == 'preparing'
              && request.resource.data.status in ['shipping', 'cancelled']
            )
            || (
              resource.data.status == 'shipping'
              && request.resource.data.status == 'cancelled'
            )
          )
          && (
            request.resource.data.status != 'cancelled'
            || request.resource.data.stockRestored == true
          );
      }

      // Customer may cancel early or confirm delivery when shipping.
      function customerStatusUpdateOk() {
        return isCustomer()
          && orderOwnedByCaller()
          && onlyStatusFieldsChanged()
          && (
            (
              resource.data.status in ['placed', 'confirmed', 'pending']
              && request.resource.data.status == 'cancelled'
              && request.resource.data.stockRestored == true
            )
            || (
              resource.data.status == 'shipping'
              && request.resource.data.status == 'delivered'
            )
          );
      }

      function staffPaymentUpdateOk() {
        return isStaff()
          && onlyPaymentFieldsChanged()
          && (
            (
              resource.data.paymentStatus in ['unpaid', 'pending']
              && request.resource.data.paymentStatus == 'paid'
              && resource.data.status != 'cancelled'
            )
            || (
              resource.data.paymentStatus == 'paid'
              && request.resource.data.paymentStatus == 'refunded'
              && resource.data.status == 'cancelled'
            )
          );
      }

      function emailMatchesAuth() {
        return request.auth.token.email is string
          && request.resource.data.userEmail is string
          && request.resource.data.userEmail.lower()
            == request.auth.token.email.lower();
      }

      allow read: if signedIn()
        && (
          isStaff()
          || (
            request.auth.token.email is string
            && resource.data.userEmail is string
            && resource.data.userEmail.lower() == request.auth.token.email.lower()
          )
        );
      // Customer place-order: must be customer role, own email, status placed.
      allow create: if signedIn()
        && isCustomer()
        && emailMatchesAuth()
        && request.resource.data.totalAmount is number
        && request.resource.data.totalAmount > 0
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.status == 'placed'
        && request.resource.data.paymentMethod in [
          'cash_on_delivery',
          'bank_transfer',
          'mock_wallet'
        ]
        && request.resource.data.paymentStatus in ['unpaid', 'paid'];
      allow update: if staffStatusUpdateOk()
        || customerStatusUpdateOk()
        || staffPaymentUpdateOk();
      allow delete: if isStaff();
    }

    match /seedRuns/{seedId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
